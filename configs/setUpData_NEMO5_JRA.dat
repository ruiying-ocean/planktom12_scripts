chlorophyll.nc:/gpfs/data/greenocean/software/resources/ModelResources/Chlorophyll/chlorophyll.nc
mask_itf.nc:/gpfs/data/greenocean/software/resources/ModelResources/Masks/mask_itf.nc


# ========== MODEL COMPONENTS ==========
xios_server.exe:/gpfs/home/vhf24tbu/src/XIOS3/bin/xios_server.exe
nemo_NEMO5:/gpfs/home/vhf24tbu/scratch/NEMO5/cfgs/ORCA2_ICE_PLANKTOM/BLD/bin/nemo.exe


# ========== NAMELISTS ==========
namelist_cfg:/gpfs/home/vhf24tbu/scratch/NEMO5/cfgs/ORCA2_ICE_PLANKTOM/EXP00/namelist_cfg

# setUpRun.sh copies these into forcing-specific names, then toggles
# ln_rstart/nn_rstctl for NEMO5 coldstart vs restart runs.
