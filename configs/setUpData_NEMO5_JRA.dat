namelist.trc.sms:/gpfs/home/vhf24tbu/scratch/NEMO5/src/TOP/PlankTOM/namelist.trc.sms.example

namelist_ice_cfg:/gpfs/home/vhf24tbu/scratch/NEMO5/cfgs/ORCA2_ICE_PLANKTOM/EXP00/namelist_ice_cfg
