# -------------------------
#
# NEMO5 ORCA2_ICE_PLANKTOM starter configuration - JRA/transient
#
# This file is read by setUpRun.sh on the nemo5-planktom branch.
# Create and compile the NEMO5 config first:
#
#   cd /gpfs/home/vhf24tbu/scratch/NEMO5
#   ./makenemo -n ORCA2_ICE_PLANKTOM -r X3_ORCA2_ICE_PISCES -m auto -j 0
#   ./makenemo -n ORCA2_ICE_PLANKTOM -m auto --add_key 'key_planktom key_trc_atmco2' -j 4
#
# -------------------------

# ========== RUN COMPONENTS ==========
model:NEMO5
nemoVersion:NEMO5
executable:nemo
iceRestartName:restart_ice
nemoCpus:48
xiosCpus:12
useXiosServer:true
stepsPerYear:5840

yearStart:1940
yearEnd:2100

CO2:VARIABLE
forcing_mode:transient
forcing:JRA

spinupStart:1750
spinupEnd:1930

spinupRestartKeepFrequency:9999
spinupOutputKeepFrequency:10
runRestartKeepFrequency:9999
runOutputKeepFrequency:1

keepGrid_T:1
keepGrid_U:0
keepGrid_V:1
keepGrid_W:0
keepDiad:1
keepPtrc:1
keepIce:0
keepLimPhy:0
keepGflux:0

basedir:/gpfs/home/vhf24tbu/scratch/ModelRuns/

compilerKey:/gpfs/home/vhf24tbu/scratch/NEMO5/cfgs/ORCA2_ICE_PLANKTOM/cpp_ORCA2_ICE_PLANKTOM.fcm


# ========== INPUT RESOURCES ==========
# NEMO5 ORCA2 needs a domain configuration file. Replace this path with the
# actual domcfg file on Hali before running.
ORCA_R2_zps_domcfg.nc:/gpfs/home/vhf24tbu/input_data/nemo5/ORCA_R2_zps_domcfg.nc

# Restart files. NEMO5 SI3 reads restart_ice, not restart_ice_in.
restart_trc.nc:/gpfs/home/vhf24tbu/input_data/model_restart/restart_19471231_trc_RY_HOC_HuangFe.nc
restart_ice.nc:/gpfs/data/greenocean/software/resources/ModelResources/RestartFiles/restart_ice_v3.6.nc
restart.nc:/gpfs/data/greenocean/software/resources/ModelResources/RestartFiles/restart_19191231_opa_PT.nc

EMPaveFile:/gpfs/home/vhf24tbu/scratch/ModelRuns/TOM12_RY_SJ01/EMPave_1940.dat

ahmcoef.nc:/gpfs/data/greenocean/software/resources/ModelResources/EddyViscCoeff/ahmcoef.nc

atmco2.dat.variable:/gpfs/data/greenocean/software/resources/SOZONE_atmo/atmco2_ssp3-70.dat
atmco2.dat.static:/gpfs/data/greenocean/software/resources/ModelResources/AtmosCO2/atmco2_PT_v1_CONSTANT_1750.dat
atmco2cfc.dat:/gpfs/data/greenocean/software/resources/ModelResources/AtmosCO2/atmco2cfc_NEEDS_WORK.dat

bathy_level.nc:/gpfs/data/greenocean/software/resources/ModelResources/Bathymetry/bathy_level.nc
bathy_meter.nc:/gpfs/data/greenocean/software/resources/ModelResources/Bathymetry/bathy_meter.nc
bathy.orca.nc:/gpfs/data/greenocean/software/resources/ModelResources/Bathymetry/bathy.orca.nc
coordinates.nc:/gpfs/data/greenocean/software/resources/ModelResources/GridCoordinates/coordinates.nc

data_1m_potential_temperature_nomask.nc:/gpfs/data/greenocean/software/resources/ModelResources/Atlas/WOA01_ORCA2_1m_potemp.nc
data_1m_salinity_nomask.nc:/gpfs/data/greenocean/software/resources/ModelResources/Atlas/WOA01_ORCA2_1m_sal.nc

dust.orca.nc:/gpfs/data/greenocean/software/resources/ModelResources/Dust/dust.Jickells2005.times035.ORCA.nc
ndeposition.nc:/gpfs/data/greenocean/software/resources/ModelResources/Dust/ndeposition.orca.nc
river.nc:/gpfs/data/greenocean/software/resources/ModelResources/River/river.nc
runoff_core_monthly.nc:/gpfs/data/greenocean/software/resources/ModelResources/River/runoff_core_monthly.nc

