# XIOS 2.0 (group build, matches gcc-9.2.0 NEMO without key_xios3)
xios_server.exe:/gpfs/software/hali/xios/xios-2.0/bin/xios_server.exe
nemo_NEMO5:/gpfs/home/vhf24tbu/scratch/NEMO5/cfgs/ORCA2_ICE_PlankTOM/BLD/bin/nemo.exe


