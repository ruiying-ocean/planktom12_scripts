# -------------------------
#
# NEMO5 ORCA2_ICE_PlankTOM starter configuration - ERA/transient
#
# This file is read by setUpRun.sh on the nemo5-planktom branch.
# Create and compile the NEMO5 config first:
#
#   cd /gpfs/home/vhf24tbu/scratch/NEMO5
#   ./makenemo -n ORCA2_ICE_PlankTOM -r X3_ORCA2_ICE_PISCES -m auto -j 0
#   ./makenemo -n ORCA2_ICE_PlankTOM -m auto --add_key 'key_planktom key_trc_atmco2' -j 4
#
# -------------------------

# ========== RUN COMPONENTS ==========
model:NEMO5
nemoVersion:NEMO5
executable:nemo
iceRestartName:restart_ice
nemoCpus:48
xiosCpus:12
useXiosServer:true
stepsPerYear:5840

yearStart:1948
yearEnd:2024

CO2:VARIABLE
forcing_mode:transient
forcing:ERA

spinupStart:1750
spinupEnd:1940

spinupRestartKeepFrequency:9999
spinupOutputKeepFrequency:10
runRestartKeepFrequency:9999
runOutputKeepFrequency:1

keepGrid_T:1
keepGrid_U:0
keepGrid_V:1
keepGrid_W:0
keepDiad:1
keepPtrc:1
keepIce:0
keepLimPhy:0
keepGflux:0

basedir:/gpfs/home/vhf24tbu/scratch/ModelRuns/

compilerKey:/gpfs/home/vhf24tbu/scratch/NEMO5/cfgs/ORCA2_ICE_PlankTOM/cpp_ORCA2_ICE_PlankTOM.fcm


# ========== INPUT RESOURCES ==========
# NEMO5 ORCA2 reads cn_domcfg="ORCA_R2_zps_domcfg".
ORCA_R2_zps_domcfg.nc:/gpfs/home/vhf24tbu/input_data/nemo5/ORCA_R2_zps_domcfg.nc

# Restart files. NEMO5 SI3 reads restart_ice, not restart_ice_in.
restart_trc.nc:/gpfs/home/vhf24tbu/input_data/nemo5/ORCA2_01109600_restart_trc.nc
restart_ice.nc:/gpfs/home/vhf24tbu/input_data/nemo5/ORCA2_01109600_restart_ice.nc
restart.nc:/gpfs/home/vhf24tbu/input_data/nemo5/ORCA2_01109600_restart.nc


ahmcoef.nc:/gpfs/data/greenocean/software/resources/NEMO5/ahmcoef.nc
zdfiwm_forcing_orca2.nc:/gpfs/data/greenocean/software/resources/NEMO5/zdfiwm_forcing_orca2.nc
sdw_ecwaves_orca2.nc:/gpfs/data/greenocean/software/resources/NEMO5/sdw_ecwaves_orca2.nc

atmco2.dat.variable:/gpfs/data/greenocean/software/resources/SOZONE_atmo/atmco2_ssp3-70.dat
atmco2.dat.static:/gpfs/data/greenocean/software/resources/ModelResources/AtmosCO2/atmco2_PT_v1_CONSTANT_1750.dat
atmco2cfc.dat:/gpfs/data/greenocean/software/resources/ModelResources/AtmosCO2/atmco2cfc_NEEDS_WORK.dat
