# -------------------------
#
# NEMO5 ORCA2_ICE_PlankTOM12 - ERA forcing SPINUP
#
# Ported from avd22gnu's KRF12 native-port run TOM12_PT_KF70
#   (/gpfs/home/avd22gnu/scratch/ModelRuns/NEMO5/TOM12_PT_KF70/setUpData_SPINUP.dat)
# Resource / executable / namelist / XML files are HIS (unchanged paths);
# the key SCHEMA has been adapted to this repo's setUpRun.sh.
#
# PlankTOM12 (12-PFT) biogeochemistry, NEMO5 engine, ORCA2 grid.
# Read by setUpRun.sh on the nemo5 branch.
#
# Provenance notes (differences from his file, by design):
#   - model:DEV  -> model:NEMO5 + nemoVersion:NEMO5 + executable:nemo  (this repo's NEMO5 contract)
#   - opa_DEV:   -> nemo_NEMO5: (executable key matched as nemo*<Model>)
#   - forcing:ERA5 -> forcing:ERA (this repo routes the 'era' namelist/forcing prefix off "ERA")
#   - added run-control + tidyup + analysis keys this pipeline requires
#   - basedir repointed to YOUR scratch (his pointed into his own ModelRuns/)
#
# -------------------------

# ========== RUN COMPONENTS ==========
model:NEMO5
nemoVersion:NEMO5
executable:nemo
iceRestartName:restart_ice

# CONFIRMED: his namelist_ref has jpni=jpnj=0 (auto-decomposition), so any core
# count works. 48/12 mirrors your other NEMO5 ORCA2 configs.
nemoCpus:48
xiosCpus:12
useXiosServer:true

# CONFIRMED: his namelist_ref has rn_Dt=5400. and nn_itend=5840, so update_timestep.sh
# applies these as a no-op. Matches the ORCA2 standard and your NEMO5-TOM6 config.
timestep:5400
stepsPerYear:5840

yearStart:1750
yearEnd:1779

# His file set CO2:VARIABLE -> atmco2_ssp1-26.dat (reproduced verbatim below).
# For a pre-industrial spinup you may instead want CO2:STATIC (constant-1750).
CO2:VARIABLE

forcing_mode:spinup
forcing:ERA

# ---- Tidyup ----
spinupStart:1750
spinupEnd:1779
spinupRestartKeepFrequency:9999
spinupOutputKeepFrequency:10
runRestartKeepFrequency:9999
runOutputKeepFrequency:1

keepGrid_T:1
keepGrid_U:0
keepGrid_V:1
keepGrid_W:0
keepDiad:1
keepPtrc:1
keepIce:0
keepLimPhy:0
keepGflux:0

# Repointed to YOUR scratch (his was /gpfs/home/avd22gnu/scratch/ModelRuns/NEMO5/).
basedir:/gpfs/home/vhf24tbu/scratch/ModelRuns/

# His KRF12 cpp keys (drives PIIC/C14 detection in setUpRun.sh).
compilerKey:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/cpp_ORCA2_ICE_PlankTOM.fcm


# ========== INPUT RESOURCES (his paths, unchanged) ==========
# Restart files
restart_trc.nc:/gpfs/home/avd22gnu/scratch/nemo/restart/restart_17491231_trc_v5_HOC.nc
restart.nc:/gpfs/home/avd22gnu/scratch/nemo/restart/restart_17491231_opa_v5.nc
restart_ice.nc:/gpfs/home/avd22gnu/scratch/nemo/restart/ORCA2_00005840_restart_ice.nc

# Datafiles
atmco2.dat.variable:/gpfs/data/greenocean/software/resources/SOZONE_atmo/atmco2_ssp1-26.dat
atmco2.dat.static:/gpfs/data/greenocean/software/resources/ModelResources/AtmosCO2/atmco2_PT_v1_CONSTANT_1750.dat
atmco2cfc.dat:/gpfs/data/greenocean/software/resources/ModelResources/AtmosCO2/atmco2cfc_NEEDS_WORK.dat
atmb14.dat:/gpfs/data/greenocean/software/resources/SOZONE_atmo/atmb14_TJ_hm.dat
atmc14.dat:/gpfs/data/greenocean/software/resources/SOZONE_atmo/atmc14_TJ_hm.dat

# NetCDF inputs
ahmcoef.nc:/gpfs/data/greenocean/software/resources/NEMO5/ahmcoef.nc
bathy.orca.nc:/gpfs/data/greenocean/software/resources/NEMO5/bathy.orca.nc
basin_mask.nc:/gpfs/data/greenocean/software/resources/NEMO5/basin_mask.v5.nc
chlorophyll.nc:/gpfs/data/greenocean/software/resources/NEMO5/chlorophyll.nc

data_1m_potential_temperature_nomask.nc:/gpfs/home/avd22gnu/scratch/nemo/resources/data_1m_potential_temperature_nomask.nc
data_1m_salinity_nomask.nc:/gpfs/home/avd22gnu/scratch/nemo/resources/data_1m_salinity_nomask.nc

dust.orca.nc:/gpfs/data/greenocean/software/resources/NEMO5/dust.Jickells2005.times035.ORCA.v5.nc
ndeposition.nc:/gpfs/data/greenocean/software/resources/NEMO5/ndeposition.orca.v5.nc
river.nc:/gpfs/data/greenocean/software/resources/NEMO5/river.v5.nc

eddy_viscosity_2D.nc:/gpfs/data/greenocean/software/resources/NEMO5/eddy_viscosity_2D.nc
eddy_viscosity_3D.nc:/gpfs/data/greenocean/software/resources/NEMO5/eddy_viscosity_3D.nc

hydrofe.orca.nc:/gpfs/data/greenocean/software/resources/NEMO5/hydrofe.orca.nc
mask_itf.nc:/gpfs/data/greenocean/software/resources/NEMO5/mask_itf.nc
K1rowdrg.nc:/gpfs/data/greenocean/software/resources/NEMO5/K1rowdrg.nc
M2rowdrg.nc:/gpfs/data/greenocean/software/resources/NEMO5/M2rowdrg.nc
par.orca.nc:/gpfs/data/greenocean/software/resources/NEMO5/par.orca.nc
resto.nc:/gpfs/data/greenocean/software/resources/NEMO5/resto.nc

sali_ref_clim_monthly.nc:/gpfs/data/greenocean/software/resources/NEMO5/sali_ref_clim_monthly.nc
weights_3D_r360x180_bilin.nc:/gpfs/data/greenocean/software/resources/NEMO5/weights_3D_r360x180_bilin.nc


# ========== MODEL COMPONENTS ==========
# His XIOS 2.0 build (must match his nemo.exe MPI/compiler toolchain -- see VERIFY note 4).
xios_server.exe:/gpfs/software/ada/xios/2.0/gcc-openmpi/trunk/bin/xios_server.exe

# His KRF12 native-port executable (group-standard NEMO5 PlankTOM12 build).
nemo_NEMO5:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/BLD/bin/nemo.exe

# ORCA2 domain configuration
ORCA_R2_zps_domcfg.nc:/gpfs/home/avd22gnu/scratch/nemo/resources/ORCA_R2_zps_domcfg.nc


# ========== NAMELISTS ==========
# His namelist layering is inverted vs this repo (per-state variation lives in his
# namelist_ref_* variants; ours expects it in namelist_cfg_era_*). CONFIRMED on the
# HPC that his EXP00/namelist_cfg carries no real overrides -- so the complete
# 1583-line variants below ARE the full per-state config. Nothing to merge.
namelist_ref:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_ref

# coldstart = spinup year 1 -> his looping FIRST-YEAR namelist (cycling forcing, fresh start)
namelist_cfg_era_coldstart:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_ref_looping_first_year
# cycling = spinup years 2+ -> his looping namelist
namelist_cfg_era_cycling:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_ref_looping
# restart = transient continuation -> his plain restart namelist (UNUSED in spinup mode)
namelist_cfg_era_restart:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_ref

# TOP (tracer) namelists
namelist_top_ref:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_top_ref
namelist_top_cfg:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_top_cfg

# PlankTOM12 SMS parameters
namelist.trc.sms:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist.trc.sms_tom12ref

# Ice namelists
namelist_ice_ref:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_ice_ref
namelist_ice_cfg:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/namelist_ice_cfg


# ========== XIOS XML (his paths, unchanged) ==========
iodef.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/iodef.xml
context_nemo.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/context_nemo.xml
axis_def_nemo.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/axis_def_nemo.xml
domain_def_nemo.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/domain_def_nemo.xml
grid_def_nemo.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/grid_def_nemo.xml
field_def_nemo-ice.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/field_def_nemo-ice.xml
field_def_nemo-oce.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/field_def_nemo-oce.xml
field_def_nemo-planktom.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/field_def_nemo-planktom.xml
# file_def_nemo.xml:/gpfs/home/avd22gnu/scratch/nemo/KRF12/cfgs/ORCA2_ICE_PlankTOM/EXP00/file_def_nemo.xml
file_def_nemo.xml:/gpfs/home/vhf24tbu/EXP00/NEMO5/file_def_nemo.xml


# ========== ANALYSIS / VISUALISATION CONFIG ==========
# nemo5.0 configs already enumerate the full 12-PFT set -> correct for PlankTOM12.
analyser_config:analyser_config_nemo5.0.toml
visualise_config:visualise_config_nemo5.0.toml
